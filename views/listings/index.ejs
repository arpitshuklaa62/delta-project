<% layout("layouts/boilerplate.ejs") %>

<h2 class="mt-3">All Hostels</h2>



<!-- 🔍 FILTER FORM -->
<form method="GET" action="/listings" class="row g-2 mb-4">

  <div class="col-md-3">
    <input type="text" name="search" placeholder="Search location or hostel" class="form-control">
  </div>

  <div class="col-md-2">
    <select name="gender" class="form-control">
      <option value="">Gender</option>
      <option value="Boys">Boys</option>
      <option value="Girls">Girls</option>
      <option value="Both">Both</option>
    </select>
  </div>

  <div class="col-md-2">
    <select name="roomType" class="form-control">
      <option value="">Room Type</option>
      <option value="Single">Single</option>
      <option value="Double">Double</option>
      <option value="Triple">Triple</option>
    </select>
  </div>

  <div class="col-md-2">
    <input type="number" name="price" placeholder="Max Price" class="form-control">
  </div>

  <div class="col-md-2">
    <button class="btn btn-dark w-100">Filter</button>
  </div>

</form>

<!-- 🏠 HOSTEL CARDS -->
<div class="row">

  <% allListings.forEach(listing => { %>
    
    <div class="col-md-4 mb-4">
      <div class="card h-100 shadow">

        <!-- Image -->
        <% if(listing.images && listing.images.length > 0){ %>
          <img src="<%= listing.images[0].url %>" class="card-img-top" style="height:200px; object-fit:cover;">
        <% } else { %>
          <img src="https://via.placeholder.com/300x200" class="card-img-top">
        <% } %>

        <div class="card-body">

          <!-- Title -->
          <h5 class="card-title"><%= listing.title %></h5>

          <!-- Location -->
          <p>📍 <%= listing.location %></p>

          <!-- Price -->
          <p>💰 ₹<%= listing.price %>/month</p>

          <!-- Gender -->
          <p>👤 <%= listing.gender || "N/A" %></p>

          <!-- Room Type -->
          <p>🛏 <%= listing.roomType || "N/A" %></p>

          <!-- Amenities -->
          <p>
            🏠 
            <%= (listing.amenities && listing.amenities.length > 0) 
                ? listing.amenities.join(", ") 
                : "No amenities" %>
          </p>

          <!-- View Button -->
          <a href="/listings/<%= listing._id %>" class="btn btn-outline-dark btn-sm mt-2">
            View Details
          </a>

        </div>
      </div>
    </div>

  <% }) %>

</div>