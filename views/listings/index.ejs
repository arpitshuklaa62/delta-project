<% layout('layouts/boilerplate') %>

<div class="my-4">

  <style>
    /* ===== FILTERS ===== */
    #filters {
      gap: 1.8rem;
      flex-wrap: wrap;
      align-items: center;
      background: #fff;
      padding: 10px 15px;
      border-radius: 12px;
      box-shadow: 0 2px 6px rgba(0,0,0,0.05);
    }

    /* Single filter */
    .filter {
      text-align: center;
      opacity: 1.7;
      transition: 0.3s;
    }

    .filter:hover {
      opacity: 1;
      cursor: pointer;
      transform: scale(1.05);
    }

    .filter i {
      font-size: 1.2rem;
    }

    .filter p {
      font-size: 0.8rem;
      margin-top: 4px;
    }

    /* Tax toggle */
    .tax-toggle {
      border: 1px solid #ccc;
      border-radius: 1rem;
      padding: 0.5rem 1rem;
      display: flex;
      align-items: center;
      background: #fff;
      margin-left: auto;
      margin-top: -70px;
    }

    .tax-info {
      display: none;
    }

    /* ===== LISTINGS GRID ===== */
    .listings-container {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
      gap: 20px;
      padding: 10px 0;
    }

    .listings-card-wrapper {
      height: 100%;
        display: block; 
    }

    /* ===== CARDS ===== */
    .card {
  border-radius: 14px;
  overflow: hidden;
  border: none;
  background-color: #fff;
  display: block;
    height: 100%;

  transition: transform 0.25s ease, box-shadow 0.25s ease;
  will-change: transform;
}

/* ❌ scale hata diya (ye problem tha) */
.card:hover {
  transform: translateY(-6px);   /* ✅ smooth lift */
  box-shadow: 0 6px 22px rgba(0,0,0,0.18);
}

/* ✅ image stable + slight zoom */
.card-img-top {
  width: 100%;
  height: 200px;
  object-fit: cover;
  transform: scale(1);
  transition: transform 0.3s ease;
   display: block;
}

.card:hover .card-img-top {
  transform: scale(1.03); /* ✅ safe zoom */
}

/* ✅ prevent text shifting */
.card-body {
  padding: 12px 15px;
  transform: none !important;
   position: relative;
  z-index: 2;
}

    .card-title {
      font-weight: 600;
      font-size: 1rem;
      margin-bottom: 5px;
    }

    .card-text {
      color: #717171;
      font-size: 0.875rem;
      margin-bottom: 6px;
    }

    .card-price {
      font-weight: 700;
      font-size: 0.95rem;
      color: #000;
    }

    .card-rating {
      color: #ff385c;
      font-size: 0.875rem;
    }

    .badge {
      position: absolute;
      top: 10px;
      left: 10px;
      background-color: #ff385c;
      color: #fff;
      font-size: 0.75rem;
      padding: 3px 6px;
      border-radius: 6px;
    }

    /* ===== MOBILE ===== */
    @media (max-width: 991px) {
      #filters {
        flex-direction: column;
        align-items: flex-start;
      }

      .filter {
        width: 100%;
        text-align: left;
        display: flex;
        align-items: center;
        gap: 10px;
      }

      .filter i {
        font-size: 1rem;
      }

      .tax-toggle {
        width: 100%;
        margin-top: 10px;
      }
    }

    /* ===== TABLET ===== */
    @media (min-width: 768px) {
      .card-img-top {
        height: 240px;
      }
    }

    /* ===== DESKTOP ===== */
    @media (min-width: 992px) {
      #filters {
        display: flex !important;
        flex-wrap: wrap;
        align-items: center;
      }
    }

    body {
      background-color: #f7f7f7;
    }

    button {
      border-radius: 20px;
    }
  </style>

  <!-- Filters Button for Mobile -->
  <button 
    class="btn btn-outline-dark d-lg-none mb-3" 
    type="button" 
    data-bs-toggle="collapse" 
    data-bs-target="#filters">
    ☰ Filters
  </button>

  <!-- Filters Section -->
  <div id="filters" class="collapse">

  <a href="/listings?category=Trending" class="filter text-decoration-none text-dark">
    <div><i class="fa-solid fa-fire"></i></div>
    <p>Trending</p>
  </a>

  <a href="/listings?category=Rooms" class="filter text-decoration-none text-dark">
    <div><i class="fa-solid fa-bed"></i></div>
    <p>Rooms</p>
  </a>

  <a href="/listings?category=Iconic Cities" class="filter text-decoration-none text-dark">
    <div><i class="fa-solid fa-mountain-city"></i></div>
    <p>Iconic Cities</p>
  </a>

  <a href="/listings?category=Mountains" class="filter text-decoration-none text-dark">
    <div><i class="fa-solid fa-mountain"></i></div>
    <p>Mountains</p>
  </a>

  <a href="/listings?category=Castles" class="filter text-decoration-none text-dark">
    <div><i class="fa-brands fa-fort-awesome"></i></div>
    <p>Castles</p>
  </a>

  <a href="/listings?category=Amazing Pools" class="filter text-decoration-none text-dark">
    <div><i class="fa-solid fa-person-swimming"></i></div>
    <p>Amazing Pools</p>
  </a>

  <a href="/listings?category=Camping" class="filter text-decoration-none text-dark">
    <div><i class="fa-solid fa-campground"></i></div>
    <p>Camping</p>
  </a>

  <a href="/listings?category=Farms" class="filter text-decoration-none text-dark">
    <div><i class="fa-solid fa-cow"></i></div>
    <p>Farms</p>
  </a>

  <a href="/listings?category=Arctic" class="filter text-decoration-none text-dark">
    <div><i class="fa-regular fa-snowflake"></i></div>
    <p>Arctic</p>
  </a>

  <a href="/listings?category=Domes" class="filter text-decoration-none text-dark">
    <div><i class="fa-solid fa-igloo"></i></div>
    <p>Domes</p>
  </a>

  <a href="/listings?category=Boats" class="filter text-decoration-none text-dark">
    <div><i class="fa-solid fa-ship"></i></div>
    <p>Boats</p>
  </a>

  <!-- TAX TOGGLE SAME REHNE DO -->
  <div class="tax-toggle">
    <div class="form-check-reverse form-switch">
      <input class="form-check-input" type="checkbox" id="switchCheckDefault">
      <label class="form-check-label"><b>display total after taxes</b></label>
    </div>
  </div>
</div>

  

  <!-- Listings Grid -->
  <div class="listings-container mt-3">
    <% for (let listing of allListings) { %>
      <div class="listings-card-wrapper">
        <a href="/listings/<%= listing._id %>" class="text-decoration-none text-dark d-block h-100 position-relative">
          <div class="card listings-card">
            <% 
              const _defaultImage = 'https://images.unsplash.com/photo-1625505826533-5c80aca7d157?ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxzZWFyY2h8MTJ8fGdvYXxlbnwwfHwwfHx8MA%3D%3D&auto=format&fit=crop&w=800&q=60';
              const imgSrc = (listing && listing.image.url)
                ? (typeof listing.image === 'string' ? listing.image : (listing.image.url || _defaultImage))
                : _defaultImage;
            %>
            <img src="<%= imgSrc %>" class="card-img-top" alt="<%= listing.title %>" loading="lazy" />
            
            <!-- Optional Badge -->
            <% if(listing.isSuperhost) { %>
              <div class="badge">Superhost</div>
            <% } %>

            <div class="card-body">
              <h5 class="card-title mb-2"><%= listing && listing.title ? listing.title : 'Untitled' %></h5>
              <p class="card-text mb-1">&#8377; <%= (listing && listing.price != null) ? Number(listing.price).toLocaleString('en-IN') : 'N/A' %>/night
                <i class="tax-info"> &nbsp;&nbsp;+18% GST </i>
              </p>
             
            </div>
          </div>
        </a>
      </div>
    <% } %>
  </div>
</div>

<script>
  let taxSwitch = document.getElementById("switchCheckDefault");
  taxSwitch.addEventListener("click", () => {
    let taxInfo = document.getElementsByClassName("tax-info");
    for (let info of taxInfo) {
      if (info.style.display != "inline") {
        info.style.display = "inline";
      } else {
        info.style.display = "none";
      }
    }
  });
</script>