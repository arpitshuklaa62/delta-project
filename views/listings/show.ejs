<% layout("layouts/boilerplate") %>

<div class="row mt-3">
  <div class="col-8 offset-2">
    <h3><%= listing.title %></h3>
  </div>

  <!-- Listing Card -->
  <div class="card col-8 offset-2 show-card mb-3">

    <% const defaultImg = 'https://images.unsplash.com/photo-1625505826533-5c80aca7d157?auto=format&fit=crop&w=800&q=60'; %>
    <% const imgSrc = (listing.images && listing.images.length > 0) ? listing.images[0].url : defaultImg; %>

    <img src="<%= imgSrc %>" class="card-img-top" style="height:300px; object-fit:cover;">

    <% if (listing.images && listing.images.length > 1) { %>
      <div class="card-body">
        <div class="d-flex flex-wrap">
          <% listing.images.forEach(img => { %>
            <img 
              src="<%= img.url %>" 
              class="img-thumbnail me-2 mb-2"
              style="max-height: 100px; max-width: 100px; object-fit: cover; cursor: pointer;"
              onclick="this.closest('.card').querySelector('.card-img-top').src = '<%= img.url %>'"
            />
          <% }); %>
        </div>
      </div>
    <% } %>

    <div class="card-body">

      <!-- Owner -->
      <p><i>Owned by <%= listing.owner?.username || "Unknown" %></i></p>

      <!-- Description -->
      <p><%= listing.description %></p>

      <!-- Price -->
      <p>💰 ₹<%= listing.price ? listing.price.toLocaleString("en-IN") : "N/A" %> / month</p>

      <!-- Location -->
      <p>📍 <%= listing.location %></p>

      <!-- Hostel Fields -->
      <p>👤 Gender: <%= listing.gender || "N/A" %></p>
      <p>🛏 Room Type: <%= listing.roomType || "N/A" %></p>

      <!-- Amenities -->
      <p>
        🏠 Amenities:
        <%= (listing.amenities && listing.amenities.length > 0)
            ? listing.amenities.join(", ")
            : "No amenities" %>
      </p>

    </div>
  </div>

  <!-- Edit/Delete -->
  <% if(currUser && listing.owner && listing.owner._id.equals(currUser._id)) { %>
    <div class="col-8 offset-2 mb-3">
      <a href="/listings/<%= listing._id %>/edit" class="btn btn-dark">Edit</a>

      <form method="POST" action="/listings/<%= listing._id %>?_method=DELETE" class="d-inline">
        <button class="btn btn-danger">Delete</button>
      </form>
    </div>
  <% } %>

  <!-- Review Form -->
  <% if(currUser){ %>
    <div class="col-8 offset-2 mb-3">
      <hr>
      <h4>Leave a Review</h4>

      <form action="/listings/<%= listing._id %>/reviews" method="POST">

        <label>Rating</label>
        <select name="review[rating]" class="form-control mb-2">
          <option value="1">1 ⭐</option>
          <option value="2">2 ⭐</option>
          <option value="3">3 ⭐</option>
          <option value="4">4 ⭐</option>
          <option value="5">5 ⭐</option>
        </select>

        <textarea name="review[comment]" class="form-control" placeholder="Write your review" required></textarea>

        <button class="btn btn-outline-dark mt-2">Submit</button>
      </form>
    </div>
  <% } %>

  <!-- Reviews -->
  <% if(listing.reviews && listing.reviews.length > 0) { %>
    <div class="col-8 offset-2 mb-3">
      <hr>
      <h5>All Reviews:</h5>

      <% listing.reviews.forEach(review => { %>
        <div class="card mb-2">
          <div class="card-body">

            <h6>@<%= review.author?.username || "Deleted User" %></h6>

            <p>⭐ <%= review.rating %></p>
            <p><%= review.comment %></p>

            <% if(currUser && review.author && review.author._id.equals(currUser._id)) { %>
              <form method="POST" action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE">
                <button class="btn btn-danger btn-sm">Delete</button>
              </form>
            <% } %>

          </div>
        </div>
      <% }) %>

    </div>
  <% } %>

  <!-- Map -->
  <div class="col-8 offset-2 mb-3">
    <h3>📍 Location</h3>
    <div id="map" style="height: 400px;"></div>
  </div>

</div>

<!-- Leaflet -->
<link rel="stylesheet" href="https://unpkg.com/leaflet/dist/leaflet.css"/>
<script src="https://unpkg.com/leaflet/dist/leaflet.js"></script>

<script>
  const coords = <%- JSON.stringify(listing.geometry?.coordinates || [77.2090, 28.6139]) %>;

  let lat = 28.6139;
  let lon = 77.2090;

  if (coords && coords.length === 2) {
    lon = coords[0];
    lat = coords[1];
  }

  const map = L.map('map').setView([lat, lon], 13);

  L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
    attribution: '&copy; OpenStreetMap contributors'
  }).addTo(map);

  L.marker([lat, lon])
    .addTo(map)
    .bindPopup("<b><%= listing.title %></b><br><%= listing.location %>")
    .openPopup();
</script>