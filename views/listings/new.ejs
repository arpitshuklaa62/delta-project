<% layout("layouts/boilerplate.ejs") %>

<div class="row mt-3">
  <div class="col-8 offset-2">
    <h3>Add New Hostel</h3>

    <form method="POST" action="/listings" novalidate class="needs-validation" enctype="multipart/form-data">

      <!-- Title -->
      <div class="mb-3">
        <label class="form-label">Hostel Name</label>
        <input name="listing[title]" placeholder="Enter hostel name" type="text" class="form-control" required />
      </div>

      <!-- Description -->
      <div class="mb-3">
        <label class="form-label">Description</label>
        <textarea name="listing[description]" class="form-control" required></textarea>
      </div>

      <!-- Images -->
      <div class="mb-3">
        <label class="form-label">Upload Images</label>
        <input name="images" type="file" class="form-control" multiple/>
      </div> 

      <!-- Price -->
      <div class="mb-3">
        <label class="form-label">Price (per month)</label>
        <input name="listing[price]" placeholder="5000" type="number" class="form-control" required />
      </div>

      <!-- Location -->
      <div class="mb-3">
        <label class="form-label">Location</label>
        <input name="listing[location]" placeholder="Indore, MP" type="text" class="form-control" required/>
      </div>

      <!-- Country (IMPORTANT - backend me use ho raha hai) -->
      <div class="mb-3">
        <label class="form-label">Country</label>
        <input name="listing[country]" placeholder="India" type="text" class="form-control" required/>
      </div>

      <!-- Gender -->
      <div class="mb-3">
        <label class="form-label">Gender Allowed</label>
        <select name="listing[gender]" class="form-control" required>
          <option value="">Select</option>
          <option value="Boys">Boys</option>
          <option value="Girls">Girls</option>
          <option value="Both">Both</option>
        </select>
      </div>

      <!-- Room Type -->
      <div class="mb-3">
        <label class="form-label">Room Type</label>
        <select name="listing[roomType]" class="form-control" required>
          <option value="">Select</option>
          <option value="Single">Single</option>
          <option value="Double">Double</option>
          <option value="Triple">Triple</option>
        </select>
      </div>

      <!-- Amenities -->
      <div class="mb-3">
        <label class="form-label">Amenities</label><br>

        <div class="form-check form-check-inline">
          <input class="form-check-input" type="checkbox" name="listing[amenities]" value="WiFi">
          <label class="form-check-label">WiFi</label>
        </div>

        <div class="form-check form-check-inline">
          <input class="form-check-input" type="checkbox" name="listing[amenities]" value="AC">
          <label class="form-check-label">AC</label>
        </div>

        <div class="form-check form-check-inline">
          <input class="form-check-input" type="checkbox" name="listing[amenities]" value="Mess">
          <label class="form-check-label">Mess</label>
        </div>

        <div class="form-check form-check-inline">
          <input class="form-check-input" type="checkbox" name="listing[amenities]" value="Parking">
          <label class="form-check-label">Parking</label>
        </div>
      </div>

      <!-- Submit -->
      <button class="btn btn-dark mt-3">Add Hostel</button>

    </form>
  </div>
</div>