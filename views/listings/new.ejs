<% layout("layouts/boilerplate.ejs") %>

<div class="row mt-3">
  <div class="col-8 offset-2">
    <h3>Create a New Listing</h3>
    <br>

    <form method="POST" action="/listings" novalidate class="needs-validation" enctype="multipart/form-data">

      <!-- Title -->
      <div class="mb-3">
        <label class="form-label">Title</label>
        <input name="listing[title]" placeholder="Add a catchy title" type="text" class="form-control" required />
        <div class="valid-feedback">Looks good!</div>
      </div>

      <!-- Description -->
      <div class="mb-3">
        <label class="form-label">Description</label>
        <textarea name="listing[description]" class="form-control" required></textarea>
        <div class="invalid-feedback">Please enter a short description</div>
      </div>

      <!-- CATEGORY (NEW ADD) -->
      <div class="mb-3">
        <label class="form-label">Category</label>
        <select name="listing[category]" class="form-control" required>
          <option value="">Select Category</option>
          <option value="Trending">Trending</option>
          <option value="Rooms">Rooms</option>
          <option value="Iconic Cities">Iconic Cities</option>
          <option value="Mountains">Mountains</option>
          <option value="Castles">Castles</option>
          <option value="Amazing Pools">Amazing Pools</option>
          <option value="Camping">Camping</option>
          <option value="Farms">Farms</option>
          <option value="Arctic">Arctic</option>
          <option value="Domes">Domes</option>
          <option value="Boats">Boats</option>
        </select>
      </div>

      <!-- Image Upload -->
      <div class="mb-3">
        <label class="form-label">Upload Listing Image</label>
        <input name="image" type="file" class="form-control"/>
      </div> 

      <!-- Price & Country -->
      <div class="row">
        <div class="mb-3 col-md-4">
          <label class="form-label">Price</label>
          <input name="listing[price]" placeholder="1200" type="number" class="form-control" required />
          <div class="invalid-feedback">Enter a valid price</div>
        </div>

        <div class="mb-3 col-md-8">
          <label class="form-label">Country</label>
          <input name="listing[country]" placeholder="India" type="text" class="form-control" required/>
          <div class="invalid-feedback">Enter valid country</div>
        </div>
      </div>  

      <!-- Location -->
      <div class="mb-3">
        <label class="form-label">Location</label>
        <input name="listing[location]" placeholder="Jaipur, Rajasthan" type="text" class="form-control" required/>
        <div class="invalid-feedback">Enter valid location</div>
      </div>

      <!-- Submit -->
      <button class="btn btn-dark add-btn mt-3">Add</button>

    </form>
    <br>
  </div>
</div>